{
  "productName": "SENNI",
  "version": "0.1.0",
  "identifier": "com.senni.desktop",
  "build": {
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SENNI",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8000; connect-src http://localhost:8000 ws://localhost:8000; img-src 'self' http://localhost:8000 data: blob:; media-src 'self' http://localhost:8000 blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../dist/senni-backend/": "senni-backend/"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0RTUzN0VCNjUzNDA3QUEKUldTcUJ6Umw2emZsMUphNElDMEN0VHJ5dGlqalNjQ1E3cEcrM1ZGcXBOWjF0RDA4d1NacWprby8K",
      "endpoints": [
        "https://github.com/JeKoski/SENNI/releases/latest/download/latest.json"
      ]
    }
  }
}
