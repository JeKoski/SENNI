{
  "productName": "SENNI",
  "version": "0.1.0",
  "identifier": "com.senni.app",
  "build": {
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SENNI",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8000; connect-src http://localhost:8000 ws://localhost:8000; img-src 'self' http://localhost:8000 data: blob:; media-src 'self' http://localhost:8000 blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": ["../dist/senni-backend"]
  }
}
